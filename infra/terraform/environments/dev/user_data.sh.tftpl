#!/usr/bin/env bash
set -euo pipefail

APP_DIR="/opt/cook-with-me"
RUNTIME_ENV="$APP_DIR/runtime.env"
COMPOSE_ENV="$APP_DIR/.env"
COMPOSE_FILE="$APP_DIR/docker-compose.yml"

mkdir -p "$APP_DIR"
chmod 750 "$APP_DIR"

dnf update -y
dnf install -y docker jq awscli

if ! command -v curl >/dev/null 2>&1; then
  dnf install -y curl-minimal || true
fi

systemctl enable docker
systemctl start docker

if ! docker compose version >/dev/null 2>&1; then
  mkdir -p /usr/local/lib/docker/cli-plugins
  curl -fsSL "https://github.com/docker/compose/releases/download/v2.29.7/docker-compose-linux-x86_64" \
    -o /usr/local/lib/docker/cli-plugins/docker-compose
  chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
fi

# Secrets live only in Secrets Manager and are written straight to a 600
# file the container reads via env_file - never echoed, never logged.
aws secretsmanager get-secret-value \
  --region "${aws_region}" \
  --secret-id "${app_secret_name}" \
  --query SecretString \
  --output text > /tmp/cook-secret.json

{
  echo "DATABASE_URL=$(jq -r '.DATABASE_URL // ""' /tmp/cook-secret.json)"
  echo "OPENAI_API_KEY=$(jq -r '.OPENAI_API_KEY // ""' /tmp/cook-secret.json)"
  echo "CORS_ALLOWED_ORIGINS=${cors_allowed_origins}"
  echo "AWS_REGION=${aws_region}"
  echo "COGNITO_USER_POOL_ID=${cognito_user_pool_id}"
  echo "COGNITO_APP_CLIENT_ID=${cognito_app_client_id}"
} > "$RUNTIME_ENV"

APP_MEDIA_BUCKET_NAME_VALUE=""
for i in $(seq 1 10); do
  val="$(aws ssm get-parameter \
    --region "${aws_region}" \
    --name "${app_media_bucket_ssm_param}" \
    --query Parameter.Value \
    --output text 2>/dev/null)"
  if [ -n "$val" ]; then
    APP_MEDIA_BUCKET_NAME_VALUE="$val"
    break
  fi
  echo "SSM: app-media-bucket-name not yet readable (attempt $i/10), retrying in 6s..."
  sleep 6
done

if [ -z "$APP_MEDIA_BUCKET_NAME_VALUE" ]; then
  echo "ERROR: Failed to read ${app_media_bucket_ssm_param} after 10 attempts. Aborting user_data."
  exit 1
fi

echo "APP_MEDIA_BUCKET_NAME=$APP_MEDIA_BUCKET_NAME_VALUE" >> "$RUNTIME_ENV"

chmod 600 "$RUNTIME_ENV"
rm -f /tmp/cook-secret.json

# Compose-time variable, not a container runtime variable - env_file does
# not feed Compose's own variable substitution, so it gets its own file.
echo "BACKEND_IMAGE=${backend_image}" > "$COMPOSE_ENV"
chmod 644 "$COMPOSE_ENV"

cat > "$COMPOSE_FILE" <<'COMPOSE'
services:
  backend:
    image: $${BACKEND_IMAGE}
    container_name: cook-with-me-backend
    restart: unless-stopped
    ports:
      - "80:8080"
    env_file:
      - /opt/cook-with-me/runtime.env
    environment:
      PORT: "8080"
      FLASK_ENV: "production"
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
COMPOSE

aws ecr get-login-password --region "${aws_region}" \
  | docker login --username AWS --password-stdin "${ecr_registry}"

cd "$APP_DIR"
docker compose pull || true
docker compose up -d || true
