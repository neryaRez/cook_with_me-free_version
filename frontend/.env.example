# Base URL of the Cook With Me backend API (no trailing slash).
# When this is unset, the app runs entirely on local mock data.
# When set, src/services/api.js will call the real endpoints below:
#   GET    {VITE_API_BASE_URL}/api/recipes
#   GET    {VITE_API_BASE_URL}/api/recipes/:id
#   POST   {VITE_API_BASE_URL}/api/recipes
#   POST   {VITE_API_BASE_URL}/api/recipes/:id/comments
#   POST   {VITE_API_BASE_URL}/api/ai/ask
#
# Never put secrets (e.g. OpenAI API keys) in this file - those live only
# on the backend, configured via Kubernetes Secrets.
VITE_API_BASE_URL=
