# Base URL of the Cook With Me backend API (no trailing slash).
# In production this MUST be the CloudFront-fronted HTTPS URL from Terraform
# output `backend_api_base_url` (e.g. https://dXXXXXXXXXXXXX.cloudfront.net) -
# never the raw EC2 public DNS/IP over plain HTTP. The frontend is served over
# HTTPS via CloudFront, so an http:// API URL would be blocked by the browser
# as mixed content. CI/CD writes this automatically; leave empty locally to
# run against mock data.
VITE_API_BASE_URL=

# AWS Cognito configuration (public client identifiers, not secrets).
# In production these are generated by CI/CD from Terraform outputs
# `aws_region`, `cognito_user_pool_id`, `cognito_app_client_id`.
VITE_COGNITO_REGION=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_APP_CLIENT_ID=
