# External MySQL database connection string (SQLAlchemy format).
# Example: mysql+pymysql://user:password@host:3306/cookwithme
# Leave empty to run with in-memory mock recipe data.
DATABASE_URL=

# OpenAI API key used by the Robo Chef feature.
# Leave empty to get mock Robo Chef responses.
OPENAI_API_KEY=

# Port the Flask app listens on.
PORT=8080

# Flask environment: development | production
FLASK_ENV=production

# Comma-separated list of allowed CORS origins (the frontend URL(s)).
# Example: https://cook.example.com,https://dXXXXXXXXXXXXX.cloudfront.net
CORS_ALLOWED_ORIGINS=

# AWS Cognito configuration used to validate JWT access/ID tokens.
# These are identifiers, not secrets - they tell the backend which Cognito
# user pool and app client to trust when verifying a token's signature.
AWS_REGION=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
